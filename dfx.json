{
  "canisters": {
    "backend": {
      "main": "backend/app.mo",
      "type": "motoko",
      "args": "--enhanced-orthogonal-persistence"
    },
    "frontend": {
      "dependencies": ["backend"],
      "build": "echo skip-assets-build",
      "frontend": {
        "entrypoint": "cocos_frontend/build/web-mobile/index.html"
      },
      "source": ["cocos_frontend/build/web-mobile"],
      "type": "assets"
    }
  },
  "output_env_file": ".env",
  "defaults": {
    "build": {
      "packtool": "mops sources"
    }
  }
}
